# ══════════════════════════════════════════════════════════════
# SOCIAL MACHINE — API KEYS TEMPLATE
# Copy this into your existing .env file (or rename to .env)
# Fill in the values you have — leave blank what you don't yet.
# ══════════════════════════════════════════════════════════════

# ── AI (for Writer bots) ──────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# ── YOUTUBE ───────────────────────────────────────────────────
# Download from: console.cloud.google.com → YouTube Data API v3
# File goes in: video-bot-pipeline/youtube_client_secrets.json
YOUTUBE_CLIENT_SECRETS=youtube_client_secrets.json
# Run python social_machine/auth/youtube_auth.py once to generate token
YOUTUBE_TOKEN_FILE=social_machine/queue/youtube_token.json
# Your YouTube Channel IDs (found in Studio → Settings → Channel → Advanced)
YT_CHANNEL_GG=UCxxxxxxxxxxxxxxxxxxxxxxxx
YT_CHANNEL_LO=UCxxxxxxxxxxxxxxxxxxxxxxxx
YT_CHANNEL_ML=UCxxxxxxxxxxxxxxxxxxxxxxxx

# ── INSTAGRAM / FACEBOOK (Meta Graph API) ─────────────────────
# Create at: developers.facebook.com → My Apps → Create App
# Get a Page Access Token with pages_manage_posts + instagram_content_publish
INSTAGRAM_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
IG_ACCOUNT_GG=17841400000000000
IG_ACCOUNT_LO=17841400000000001
IG_ACCOUNT_ML=17841400000000002

FACEBOOK_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
FB_PAGE_GG=100000000000001
FB_PAGE_LO=100000000000002
FB_PAGE_ML=100000000000003

# ── TIKTOK ────────────────────────────────────────────────────
# Apply at: developers.tiktok.com → Manage Apps → Content Posting API
TIKTOK_ACCESS_TOKEN=act.xxxxxxxxxxxxxxxx
TIKTOK_OPENID_GG=xxxxxxxxxxxxxxxxxxxxxxxx
TIKTOK_OPENID_LO=xxxxxxxxxxxxxxxxxxxxxxxx
TIKTOK_OPENID_ML=xxxxxxxxxxxxxxxxxxxxxxxx

# ── TWITTER / X ───────────────────────────────────────────────
# Create at: developer.twitter.com → Projects & Apps
# Needs Read + Write permissions + OAuth 1.0a User Context
TWITTER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# One token pair per channel/account:
TWITTER_TOKEN_GG=xxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_SECRET_GG=xxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_TOKEN_LO=xxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_SECRET_LO=xxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_TOKEN_ML=xxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_SECRET_ML=xxxxxxxxxxxxxxxxxxxxxxxx
