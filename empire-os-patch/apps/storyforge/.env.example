# StoryForge Engine — Environment Variables
# Copy to storyforge-engine/.env and fill in values.
# Never commit the real .env file.

# ── Empire OS signals ──────────────────────────────────────────────────────────
STORYFORGE_BASE_URL=http://localhost:8001
EMPIRE_OS_MEMORY_URL=http://localhost:3100/memory
EMPIRE_OS_EVENT_URL=http://localhost:3100/events

# ── AI providers (StoryForge Creative Council + listing copy) ──────────────────
# OpenRouter gives access to all models (Claude, Gemini, GPT, DeepSeek) via one key
OPENROUTER_API_KEY=sk-or-YOUR_KEY_HERE
# Direct Anthropic access (lower latency than OpenRouter for Claude calls)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# Local models via Ollama (free, runs offline)
OLLAMA_BASE_URL=http://localhost:11434

# ── Image providers ────────────────────────────────────────────────────────────
# Higgsfield — default cinematic rendering provider
# Activates HiggsFieldProvider in core/image/providers.py
HIGGSFIELD_API_KEY=YOUR_HIGGSFIELD_KEY_HERE
HIGGSFIELD_API_URL=https://api.higgsfield.ai

# OpenAI — image generation via DALL-E
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# ComfyUI — self-hosted, no API key required
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_CHECKPOINT=v1-5-pruned-emaonly.ckpt
