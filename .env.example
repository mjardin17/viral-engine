# Copy this file to .env and fill in your values
# Never commit .env to version control

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb   # Default: deep cinematic male (George)

# Gemini — used as a fallback image source when Pollinations gets rate-limited.
# Get a free key at https://aistudio.google.com/apikey (same key works for any
# Gemini chat usage too). Free tier covers a few hundred images/day.
GEMINI_API_KEY=your_gemini_api_key_here

# Premium video-generation nodes — each is OFF by default. Set any of these
# keys to "light up" that node; the pipeline tries them in this order
# (Higgsfield > Kling > Runway > Veo) before falling back to the free
# Pollinations/Gemini-image + Ken Burns path. Leave blank to skip a node.
HIGGSFIELD_API_KEY=
KLING_API_KEY=
RUNWAY_API_KEY=
VEO_API_KEY=
