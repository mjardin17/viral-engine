# Empire OS — Environment Variables
# Copy this file to .env and fill in your keys.
# .env is NEVER committed to git.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
HOST=localhost

# API key for all empire-os endpoints (leave blank to disable auth in dev)
# Generate a strong key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMPIRE_API_KEY=

# Directory to store persistent data (memory, events, workflow state)
DATA_DIR=.empire-data

# ── AI Providers ─────────────────────────────────────────────────────────────
#
# PROVIDER ROUTING (default strategy: cost)
#   Ollama  → local/routine: copy, summary, classification  (free, no key)
#   Claude  → code, architecture, complex reasoning
#   Gemini  → research, long-context planning, scripts
#   OpenAI  → GPT-specific features
#   Goose   → local dev agent: file ops, shell, coding execution (no key)
#
# You can run with ONLY Ollama locally and zero cloud keys.

# Ollama — local inference, auto-detected (no key needed)
# Default base URL — change only if Ollama runs on a different port
OLLAMA_BASE_URL=http://localhost:11434

# Goose — local dev agent (Block's Goose CLI), auto-detected
# If Empire OS says "Goose not found", run FIND_AND_FIX_GOOSE.bat and paste the path here
# Example: GOOSE_BIN=C:\Users\jjard\.local\bin\goose.exe
GOOSE_BIN=

# Anthropic Claude — code, architecture, complex reasoning
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — research, long-context planning, scripts
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI — GPT-specific features
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Video Pipeline ───────────────────────────────────────────────────────────
# Only needed if you wire up the Video Pipeline module
# PEXELS_API_KEY=
# ELEVEN_LABS_API_KEY=
